# Porta do servidor HTTP
PORT=4000

# String de conexao do PostgreSQL (ajuste user/senha/host conforme seu ambiente)
DATABASE_URL="postgresql://chama:chama@localhost:5432/chama_ae?schema=public"

# Segredos JWT (troque por valores longos e aleatorios em producao)
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"

# Tempo de expiracao dos tokens
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Origens permitidas para CORS (separadas por virgula). Use * para liberar tudo em dev.
CORS_ORIGIN="*"
