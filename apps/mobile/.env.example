# URL base da API. Em dispositivo fisico use o IP da sua maquina (ex: http://192.168.0.10:4000).
# No emulador Android use http://10.0.2.2:4000. No iOS simulator use http://localhost:4000.
EXPO_PUBLIC_API_URL=http://localhost:4000

# Necessario em monorepo (npm workspaces): faz o Metro usar a raiz do monorepo
# como server root, resolvendo pacotes "hoisted" como o expo-router.
EXPO_USE_METRO_WORKSPACE_ROOT=1
